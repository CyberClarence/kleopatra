{
  "name": "kleopatra",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "electron:dev": "node scripts/electron-dev.mjs",
    "electron:build": "BUILD_STANDALONE=1 NEXT_PUBLIC_SYNC_API_URL=\"${NEXT_PUBLIC_SYNC_API_URL:-https://kleopatra.app}\" next build && electron-builder",
    "electron:release": "set -a && . ./.env.signing && set +a && bun run electron:build"
  },
  "build": {
    "appId": "app.kleopatra.desktop",
    "productName": "Kleopatra",
    "electronVersion": "43.1.1",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "package.json",
      "!node_modules/**/*"
    ],
    "afterPack": "scripts/electron-afterpack.cjs",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "electron/icon.png",
      "hardenedRuntime": true,
      "notarize": true,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    },
    "npmRebuild": false
  },
  "dependencies": {
    "immer": "^10.1.1",
    "lucide-react": "^0.417.0",
    "next": "^16.1.6",
    "openpgp": "^5.11.2",
    "posthog-js": "^1.399.2",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "electron": "43.1.1",
    "electron-builder": "^26.15.3",
    "eslint": "^8",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}