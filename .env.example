# --- Online sync backend ---

# Email delivery of the 6-digit verification codes — configure ONE provider.
# Without one, dev mode prints the code to the server console and shows it in the UI.
RESEND_API_KEY=
POSTMARK_API_TOKEN=
POSTMARK_FROM_EMAIL=
EMAIL_FROM="Kleopatra <no-reply@yourdomain.com>"

# Persistent storage — configure ONE backend; REQUIRED in production/Vercel.
# Without one, a local JSON file (.data/sync-store.json) is used (dev only).
SYNC_DATABASE_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Secret used to generate decoy salts for unknown emails (anti account-enumeration).
SYNC_SERVER_SECRET=

# --- Electron ---
# Set at build time so the desktop app syncs against your hosted server
# instead of its bundled local one, e.g. https://kleopatra.app
NEXT_PUBLIC_SYNC_API_URL=
